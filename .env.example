# ──────────────────────────────────────────────────────────────
#  SchedulePress E2E — environment variables
#  Copy this file to .env and adjust as needed.
#  The .env file is git-ignored; never commit real credentials.
# ──────────────────────────────────────────────────────────────

# WordPress base URL (must match the port exposed in docker-compose.yml)
WP_BASE_URL=http://localhost:8080

# Admin credentials (must match what wp-setup.sh installs)
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin

# Plugin paths relative to this project root
# (used by docker-compose volume mounts)
PLUGIN_FREE_PATH=../wpsp/wp-scheduled-posts
# PLUGIN_PRO_PATH=../wpsp/wp-scheduled-posts-pro
