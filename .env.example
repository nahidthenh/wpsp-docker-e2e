# ──────────────────────────────────────────────────────────────
#  SchedulePress E2E — environment variables
#  Copy this file to .env and adjust as needed.
#  The .env file is git-ignored; never commit real credentials.
# ──────────────────────────────────────────────────────────────

# WordPress base URL (must match the port exposed in docker-compose.yml)
WP_BASE_URL=http://localhost:8080

# Admin credentials (must match what wp-setup.sh installs)
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin

# ── Plugin paths ────────────────────────────────────────────────────────────
# Absolute or relative paths to locally cloned plugin repos.
# These are mounted read-only into the WordPress Docker container.
#
# PLUGIN_FREE_PATH  — wp-scheduled-posts (free, required)
# PLUGIN_PRO_PATH   — wp-scheduled-posts-pro (optional, omit for free-only mode)
#
# Expected local folder layout (sibling directories):
#   ../wpsp/wp-scheduled-posts/        ← free plugin repo
#   ../wpsp/wp-scheduled-posts-pro/    ← PRO plugin repo (optional)
#
# Branch-driven test workflow:
#   bash scripts/setup-branch.sh --free-branch=feature/my-branch
#   bash scripts/setup-branch.sh --free-branch=feat/x --pro-branch=feat/y
#   This script checks out the branch in the plugin folder and restarts Docker.
PLUGIN_FREE_PATH=../wpsp/wp-scheduled-posts
PLUGIN_PRO_PATH=../wpsp/wp-scheduled-posts-pro
